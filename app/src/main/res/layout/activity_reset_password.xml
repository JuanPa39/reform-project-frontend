<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:padding="28dp"
    android:gravity="center"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A2E4A">

    <!-- Ícono / Decoración -->
    <View
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:background="#243B5E"
        android:layout_marginBottom="24dp"/>

    <!-- Título -->
    <View
        android:layout_width="48dp"
        android:layout_height="3dp"
        android:background="#4FC3F7"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"/>
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Cambiar Contraseña"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:gravity="center"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Ingresa tu correo y la nueva contraseña"
        android:textSize="13sp"
        android:textColor="#FFFFFF"
        android:gravity="center"
        android:layout_marginBottom="36dp"/>

    <!-- Correo -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="CORREO"
        android:textSize="11sp"
        android:textColor="#FFFFFF"
        android:letterSpacing="0.08"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/editCorreoReset"
        android:hint="ejemplo@correo.com"
        android:textColor="#FFFFFF"
        android:background="#243B5E"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginBottom="20dp"/>

    <!-- Nueva contraseña -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="NUEVA CONTRASEÑA"
        android:textSize="11sp"
        android:textColor="#FFFFFF"
        android:letterSpacing="0.08"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/editNuevaContrasena"
        android:hint="••••••••"
        android:textColor="#FFFFFF"
        android:inputType="textPassword"
        android:background="#243B5E"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginBottom="32dp"/>

    <Button
        android:id="@+id/buttonCambiarContrasena"
        android:text="CAMBIAR CONTRASEÑA"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:letterSpacing="0.06"
        android:backgroundTint="#1565C0"
        android:layout_width="match_parent"
        android:layout_height="52dp"/>

</LinearLayout>