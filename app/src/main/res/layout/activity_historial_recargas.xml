<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1A2E4A">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#0D1B2A"
        android:titleTextColor="#FFFFFF"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Filtrar por fecha"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/buttonFechaInicio"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Inicio"
                android:layout_marginEnd="8dp"
                android:backgroundTint="#2196F3"/>

            <Button
                android:id="@+id/buttonFechaFin"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Fin"
                android:backgroundTint="#2196F3"/>
        </LinearLayout>

        <TextView
            android:id="@+id/textFechaInicio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Inicio: --"
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:layout_marginTop="8dp"/>

        <TextView
            android:id="@+id/textFechaFin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Fin: --"
            android:textColor="#AAAAAA"
            android:textSize="12sp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tipo de combustible"
            android:textColor="#FFFFFF"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="8dp"/>

        <Spinner
            android:id="@+id/spinnerCombustible"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="#243B5E"/>

        <Button
            android:id="@+id/buttonFiltrar"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Aplicar filtros"
            android:layout_marginTop="16dp"
            android:backgroundTint="#4CAF50"/>

    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone"/>

    <ListView
        android:id="@+id/listViewRecargas"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="#FFFFFF"
        android:dividerHeight="1dp"
        android:padding="8dp"/>

</LinearLayout>